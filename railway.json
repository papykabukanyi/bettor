{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn \"src.dashboard:app\" --bind 0.0.0.0:$PORT --workers 1 --worker-class gthread --threads 8 --timeout 120 --keep-alive 5",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
