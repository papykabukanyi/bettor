{
  "version": 2,
  "builds": [
    {
      "src": "src/dashboard.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/dashboard.py"
    }
  ],
  "crons": [
    {
      "path": "/api/kalshi/automation/tick",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
