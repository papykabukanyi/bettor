# =============================================================================
# Betting Bot - API Keys Configuration
# Copy this file to .env and fill in your keys
# =============================================================================

# --- The Odds API (free tier: 500 req/month) ---
# Sign up free at: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# --- football-data.org (free tier: 10 competitions, 10 req/min) ---
# Sign up free at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# --- NewsAPI (free tier: 100 req/day) ---
# Sign up at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# --- BallDontLie (NBA/WNBA — free tier) ---
# Sign up at: https://app.balldontlie.io/
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# --- RapidAPI (free-api-live-football-data) ---
# Subscribe (free) at: https://rapidapi.com/search/football
RAPIDAPI_KEY=your_rapidapi_key_here

# --- TheSportsDB (free tier — key=1 for public data, no account needed) ---
THESPORTSDB_API_KEY=1

# --- SportsData.io (trial key — covers MLB, NBA, Soccer, NFL) ---
# Sign up at: https://sportsdata.io
SPORTSDATA_API_KEY=your_sportsdata_key_here

# --- Settings ---
# Minimum edge over implied odds to flag a value bet (e.g. 0.05 = 5%)
MIN_VALUE_EDGE=0.05

# Kelly fraction (1.0 = full Kelly, 0.25 = quarter Kelly - more conservative)
KELLY_FRACTION=0.25

# Bankroll in USD
BANKROLL=1000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:port/dbname
