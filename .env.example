# =============================================================================
# Kalshi Perps Bot - Environment Configuration
# Copy this file to .env locally, or paste the values into Render.
# For KALSHI_PRIVATE_KEY, both formats work:
# 1) one line with \n escapes, or
# 2) full multiline PEM block exactly as generated.
# =============================================================================

# --- Hugging Face (dataset archive + trained direction model) ---
HF_API_KEY=your_hf_write_token_here
HF_DATASET_REPO=papylove/kalshi-perps-data
HF_MODEL_REPO=papylove/kalshi-perps-model

# --- Kalshi credentials ---
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_TIMEOUT_SEC=15

# Real order placement is OFF until you explicitly set this to 1. Everything
# runs dry-run (no real orders) regardless of the scheduler below.
KALSHI_PERPS_LIVE_TRADING_ENABLED=0

# --- Scheduler ---
# Master switch for the trading-cycle scheduler. Data-collect + daily
# retrain always run regardless of this flag; this only gates the loops that
# can eventually place real orders (still dry-run unless the flag above is
# also set). Two separate loops, on purpose: a fast one that ONLY manages an
# already-open position (so a quick move gets a quick exit), and a slower one
# that scans all 16 instruments for a new entry.
ENABLE_PERPS_SCHEDULER=1
PERPS_FAST_CHECK_SECONDS=20
PERPS_CYCLE_MINUTES=2
PERPS_DATA_COLLECT_MINUTES=15
PERPS_TRAIN_HOUR_ET=3

# --- Money / growth strategy ---
# "Break the balance into portions and grow it": each new position is sized
# at this fraction of CURRENT available balance (so it compounds), using
# each market's own embedded leverage (e.g. ~6x on KXBTCPERP) -- the portion
# is spent as MARGIN, and however many contracts that margin + leverage
# controls is what gets bought, not a fixed 1-contract size regardless of
# account size. Up to PERPS_MAX_CONCURRENT_POSITIONS can be open at once
# (5 x 20% = the whole account deployed across up to 5 different
# instruments), never more than one position per instrument at a time.
PERPS_POSITION_SIZE_PCT=0.20
PERPS_MAX_CONCURRENT_POSITIONS=5
PERPS_TAKE_PROFIT_PCT=0.004
PERPS_STOP_LOSS_PCT=0.008
# "Take profit fast on a quick move": if a position is already up at least
# PERPS_QUICK_PROFIT_PCT (smaller than the standard take-profit) AND that
# gain arrived within PERPS_QUICK_PROFIT_WINDOW_SECONDS at a rate of at least
# PERPS_QUICK_PROFIT_VELOCITY_PCT_PER_MIN (measured from Kalshi's own price
# OR an independent live exchange cross-check, whichever shows it first),
# exit immediately instead of waiting for the standard take-profit level.
PERPS_QUICK_PROFIT_PCT=0.0015
PERPS_QUICK_PROFIT_VELOCITY_PCT_PER_MIN=0.006
PERPS_QUICK_PROFIT_WINDOW_SECONDS=90
PERPS_MAX_HOLD_MINUTES=30
PERPS_ENTRY_DIP_PCT=0.0015
PERPS_SHORT_MA_MINUTES=15
PERPS_TREND_FILTER_DOWN_PCT=0.02
# Tuned via a full-history backtest (see perps_strategy.py comment) --
# ~600 trades/day at 54% win rate vs. ~36/day at 58% for the old 0.55.
PERPS_MODEL_CONFIDENCE_MIN=0.52
# Daily loss cap as a PERCENTAGE of the balance measured at the start of the
# day (not a fixed dollar figure), so it scales with the account as it grows.
PERPS_DAILY_LOSS_CAP_PCT=0.15
# Reject a new entry if Kalshi's quote and an independent live exchange price
# disagree by more than this -- a safety check against a stale/erroneous tick.
PERPS_MAX_ENTRY_PRICE_DEVIATION_PCT=0.02
PERPS_LABEL_HORIZON_MINUTES=30
PERPS_MIN_TRAIN_ROWS=300
# Caps training to the most recent N rows -- the HF archive grows daily
# forever, and this bounds memory use on a 512MB Render instance regardless
# of how much history has accumulated. Rarely needs changing.
PERPS_MAX_TRAIN_ROWS=150000

# --- API Ninjas (optional additional live crypto price cross-check) ---
# NOTE: the free/non-premium tier of this key returns prices delayed ~15
# minutes -- it's used only as a last-resort fallback, never for timing.
API_NINJAS_API_KEY=

# --- CryptoPanic (optional, better crypto news signal) ---
# CryptoPanic's public API now requires a real token (their old fully-open
# endpoint is Cloudflare-gated). Free to sign up, no credit card:
#   1. Create an account at https://cryptopanic.com
#   2. Get your free token at https://cryptopanic.com/developers/api/
#   3. Paste it below
# Not required -- Google News RSS + CoinTelegraph/CryptoSlate/Decrypt RSS
# (all free, no key) already cover news sentiment without this.
CRYPTOPANIC_API_KEY=

# --- newsdata.io (optional, additional crypto news signal) ---
# Free tier, no credit card: sign up at https://newsdata.io, get your key
# from the dashboard, paste it below. Shared account-wide daily quota across
# every coin this bot watches, so treat it as a bonus source that may go
# quiet once the day's quota is used -- not required.
NEWSDATA_API_KEY=

# Optional: lock down the manual tick/collect/train endpoints
CRON_SECRET=
