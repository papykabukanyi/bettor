# =============================================================================
# Betting Bot - API Keys Configuration
# Copy this file to .env and fill in your keys
# =============================================================================

# --- Optional external API provider ---
# Leave empty to use free GitHub Action snapshots committed in modal_data/
PREDICTIONS_API_URL=

# --- Optional Modal deployment (if you still want remote jobs) ---
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here
MODAL_API_URL=https://your-modal-app-url.modal.run
MODAL_VOLUME_NAME=bettor-data
MODAL_BOOTSTRAP_DAYS=365
MODAL_DAILY_BACKFILL_DAYS=3

# --- Polymarket execution ---
POLYMARKET_KEY_ID=your_polymarket_key_id_here
POLYMARKET_SECRET_KEY=your_base64_secret_key_here
POLYMARKET_API_PASSPHRASE=optional_if_required
POLYMARKET_PRIVATE_KEY=optional_wallet_private_key_for_legacy_clob
POLYMARKET_FUNDER=optional_funder_address
POLYMARKET_DRY_RUN=true
POLYMARKET_MIN_BET_USD=1
POLYMARKET_MAX_BET_USD=25
POLYMARKET_SLIPPAGE_BUFFER=0.02

# --- The Odds API (free tier: 500 req/month) ---
ODDS_API_KEY=your_odds_api_key_here

# --- football-data.org (free tier: 10 competitions, 10 req/min) ---
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# --- NewsAPI (free tier: 100 req/day) ---
NEWS_API_KEY=your_newsapi_key_here

# --- BallDontLie (NBA/WNBA — free tier) ---
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# --- RapidAPI (free-api-live-football-data) ---
RAPIDAPI_KEY=your_rapidapi_key_here

# --- TheSportsDB (free tier — key=1 for public data, no account needed) ---
THESPORTSDB_API_KEY=1

# --- SportsData.io (trial key — covers MLB, NBA, Soccer, NFL) ---
SPORTSDATA_API_KEY=your_sportsdata_key_here

# --- Settings ---
MIN_VALUE_EDGE=0.05
KELLY_FRACTION=0.25
BANKROLL=1000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:port/dbname
