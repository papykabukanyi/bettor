# =============================================================================
# Betting Bot - Environment Configuration
# Copy this file to .env locally, or paste the values into Render.
# For KALSHI_PRIVATE_KEY, both formats work:
# 1) one line with \n escapes, or
# 2) full multiline PEM block exactly as generated.
# =============================================================================

# --- Hugging Face core ---
HF_API_KEY=your_hf_write_token_here
HF_DATASET_REPO=papylove/sportprediction
HF_MODEL_REPO=papylove/sportprediction
HF_INFERENCE_MODEL=
HF_INFERENCE_ENDPOINT=
HF_ACTIVE_SCAN_MINUTES=30
HF_ACTIVE_APPEND_DAYS=3
HF_RETRAIN_INTERVAL_MINUTES=180

# --- Optional HF Space API proxy for dashboard ---
HF_SPACE_API_URL=
HF_SPACE_REPO=papylove/sportprediction
PREDICTIONS_API_URL=

# Cloudflare Pages frontend -> Render backend proxy
BACKEND_BASE_URL=

# --- Kalshi execution ---
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----
KALSHI_LIVE_TRADING_ENABLED=0
KALSHI_AUTOBET_STAKE_USD=1.0
KALSHI_AUTOBET_MAX_SINGLE_ORDERS=1
KALSHI_AUTOBET_MAX_COMBO_ORDERS=1
KALSHI_AUTO_CREATE_COMBOS=1
KALSHI_AUTO_PLACE_COMBOS=1
KALSHI_AUTOBET_ENABLED=1
KALSHI_COMBO_ARTIFACT_MAX=50
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_TIMEOUT_SEC=15
PREGAME_ANALYSIS_LEAD_MINUTES=90
PREGAME_BET_LEAD_MINUTES=60
PREGAME_TIMING_MINUTES=5
AUTOBET_MIN_CONFIDENCE=52

# Set AUTOBET_DRY_RUN=0 only when you intentionally want live order placement.
AUTOBET_DRY_RUN=1

# Optional: lock down Render cron endpoint
CRON_SECRET=

# --- The Odds API (free tier: 500 req/month) ---
ODDS_API_KEY=your_odds_api_key_here

# --- football-data.org (free tier: 10 competitions, 10 req/min) ---
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# --- NewsAPI (free tier: 100 req/day) ---
NEWS_API_KEY=your_newsapi_key_here

# --- NewsData.io (free tier: 200 req/day) ---
NEWSDATA_API_KEY=your_newsdata_api_key_here

# --- BallDontLie (NBA/WNBA — free tier) ---
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# --- football-data.org (required for soccer in HF plan) ---
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# --- Jeff Sackmann tennis archive local path (optional but recommended) ---
TENNIS_JEFF_SACKMANN_DIR=

# --- Cricket data sources (all optional / free-tier friendly) ---
# Cricsheet: local folder with JSON files and/or downloaded ZIP archives
CRICKET_CRICSHEET_DIR=
# Kaggle: local folder with CSVs (IPL / ICC historical datasets)
CRICKET_KAGGLE_DATA_DIR=
# CricAPI
CRICAPI_BASE_URL=https://api.cricapi.com/v1
CRICAPI_KEY=
# RapidAPI cricket feed
CRICKET_RAPIDAPI_BASE_URL=https://cricket-live-data.p.rapidapi.com
CRICKET_RAPIDAPI_HOST=cricket-live-data.p.rapidapi.com
CRICKET_RAPIDAPI_KEY=
# Deep references (used for wiring/documentation and optional adapters)
CRICKET_STATSGURU_BASE_URL=https://stats.espncricinfo.com
CRICKET_ARCHIVE_BASE_URL=https://cricketarchive.com
ESPN_CRICKET_NEWS_RSS_URL=https://www.espncricinfo.com/rss/content/story/feeds/0.xml

# --- Settings ---
MIN_VALUE_EDGE=0.05
KELLY_FRACTION=0.25
BANKROLL=1000

# --- Database (PostgreSQL, optional) ---
DATABASE_URL=postgresql://user:password@host:port/dbname
